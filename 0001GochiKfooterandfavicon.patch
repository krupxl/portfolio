 <footer class="footer">
   <div class="footer__inner">
-    <span class="footer__mark"><span class="footer__mark-k">K</span><span class="footer__mark-t">T</span></span>
+    <span class="footer__mark">K</span>
     <span class="footer__copy">© 2026 · Built in London</span>
